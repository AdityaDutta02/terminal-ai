# Postgres
POSTGRES_PASSWORD=changeme

# Redis
REDIS_PASSWORD=changeme

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://terminalai.app

# Embed token signing
EMBED_TOKEN_SECRET=generate-with-openssl-rand-base64-32

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...

# Internal service URL (used by platform to talk to gateway)
GATEWAY_INTERNAL_URL=http://gateway:3001

# Meilisearch
MEILI_MASTER_KEY=generate-with-openssl-rand-base64-32

# Razorpay
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# MinIO (object storage)
MINIO_ROOT_USER=terminalai
MINIO_ROOT_PASSWORD=generate-with-openssl-rand-base64-32

# Internal service auth (used between platform ↔ deploy-manager ↔ mcp-server)
INTERNAL_SERVICE_TOKEN=generate-with-openssl-rand-base64-32

# Deploy Manager
COOLIFY_URL=https://coolify.yourvps.com
COOLIFY_TOKEN=...
COOLIFY_SERVER_UUID=   # Coolify → Servers → click server → UUID in URL/info panel
COOLIFY_PROJECT_UUID=  # Coolify → Projects → click project → UUID in URL
GATEWAY_URL=http://<VPS1_IP>:3001  # External IP of VPS1 — injected into deployed apps
CLOUDFLARE_TOKEN=...
CLOUDFLARE_ZONE_ID=...
VPS2_IP=1.2.3.4
